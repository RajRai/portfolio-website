# Admin key required for moderation endpoints
ADMIN_KEY=change-me

# Optional: used to salt IP hashes. If unset, a default is used.
IP_HASH_SALT=change-me-too

# Server port
PORT=5174

# In dev, allow Vite origin
DEV_CLIENT_ORIGIN=http://localhost:5173

# Optional: enable PostHog analytics and session replay via the backend proxy.
POSTHOG_PROJECT_TOKEN=
POSTHOG_REGION=us

# Optional overrides if you use EU or a custom/self-hosted PostHog setup.
# POSTHOG_API_HOST=https://us.i.posthog.com
# POSTHOG_ASSET_HOST=https://us-assets.i.posthog.com
# POSTHOG_UI_HOST=https://us.posthog.com
